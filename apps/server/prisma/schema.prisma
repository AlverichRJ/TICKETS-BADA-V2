generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum TicketPriority {
  HIGH
  MEDIUM
  LOW
}

enum TicketStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

enum DeviceState {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

enum LoanStatus {
  ACTIVE
  RETURNED
}

enum FileType {
  RESPONSIVA
  INE
  OTHER
}

enum AuditAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  ASSIGNED
  CLOSED
  FILE_ATTACHED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  googleId  String?  @unique
  role      Role     @default(USER)
  avatarUrl String?
  isActive  Boolean  @default(true)
  lastLoginAt DateTime?
  loginCount Int      @default(0)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdTickets Ticket[] @relation("TicketCreator")
  assignedTickets Ticket[] @relation("TicketLeader")
  assignedDevices Device[]
  files File[]
  auditLogs TicketAudit[]
  deliveredDeviceHistory DeviceDeliveryHistory[]

  @@index([departmentId])
}

model Device {
  id          String      @id @default(cuid())
  assignedUserId String?
  assignedUser   User?   @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedComputerEquipmentId String?
  assignedComputerEquipment   ComputerEquipment? @relation(fields: [assignedComputerEquipmentId], references: [id], onDelete: SetNull)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  equipment   String
  serialNumber String    @unique
  state       DeviceState @default(AVAILABLE)
  description String?
  loanStatus  LoanStatus  @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tickets Ticket[]
  files   File[]
  deliveryHistory DeviceDeliveryHistory[]

  @@index([assignedUserId])
  @@index([assignedComputerEquipmentId])
  @@index([departmentId])
  @@index([serialNumber])
}

model ComputerEquipment {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignedDevices Device[]
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users   User[]
  devices Device[]
}

model DeviceDeliveryHistory {
  id                         String             @id @default(cuid())
  deviceId                   String
  device                     Device             @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deliveredById              String?
  deliveredBy                User?              @relation(fields: [deliveredById], references: [id], onDelete: SetNull)
  previousAssignedUserId     String?
  previousAssignedUserName   String
  previousAssignedUserEmail  String?
  previousDepartmentId       String?
  previousDepartmentName     String?
  previousComputerEquipmentId String?
  previousComputerEquipmentName String?
  equipment                  String
  serialNumber               String
  state                      DeviceState
  description                String?
  notes                      String?
  deliveredAt                DateTime           @default(now())
  createdAt                  DateTime           @default(now())

  @@index([deviceId])
  @@index([deliveredById])
  @@index([previousDepartmentId])
  @@index([deliveredAt])
}

model Ticket {
  id            String         @id @default(cuid())
  publicId      String         @unique
  creatorId     String
  creator       User           @relation("TicketCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  leaderId      String?
  leader        User?          @relation("TicketLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  deviceId      String?
  device        Device?        @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  failureDescription String
  deviceSpecs   String?
  reportedAt    DateTime       @default(now())
  priority      TicketPriority @default(MEDIUM)
  status        TicketStatus   @default(PENDING)
  resolvedAt    DateTime?
  technicalNotes String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  auditLogs TicketAudit[]

  @@index([creatorId])
  @@index([leaderId])
  @@index([deviceId])
  @@index([status])
  @@index([priority])
}

model TicketAudit {
  id        String      @id @default(cuid())
  ticketId  String
  ticket    Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    AuditAction
  fromStatus TicketStatus?
  toStatus   TicketStatus?
  notes     String?
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([ticketId])
  @@index([actorId])
}

model File {
  id           String   @id @default(cuid())
  originalName String
  storedName   String   @unique
  mimeType     String
  sizeBytes    Int
  path         String
  type         FileType @default(OTHER)
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  deviceId     String?
  device       Device?  @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  uploadedById String?
  uploadedAt   DateTime @default(now())

  @@index([userId])
  @@index([deviceId])
}

model TicketSequence {
  id    Int @id @default(1)
  value Int @default(0)
}
