# Entorno general
NODE_ENV=development
PORT=4000
PUBLIC_APP_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000

# Base de datos PostgreSQL
DATABASE_URL=postgresql://tickets_user:tickets_password@localhost:5432/tickets_inventory?schema=public

# Seguridad
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
COOKIE_NAME=sistema_tickets_session
CORS_ORIGIN=http://localhost:5173

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Usuarios administradores iniciales separados por coma
ADMIN_EMAILS=admin@empresa.com,rh@empresa.com

# Archivos locales
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10
