# Tickets BADABUN - variables locales de ejemplo. No colocar secretos reales en GitHub.
NODE_ENV=production
PORT=4000
PUBLIC_APP_URL=http://ticketsbd.ddns.net
CORS_ORIGIN=http://ticketsbd.ddns.net

# MySQL local. Ajusta usuario, password, host y base en /var/www/tickets/.env
DATABASE_URL=mysql://tickets_user:CAMBIAR_PASSWORD@127.0.0.1:3306/badabun_tickets

# Google OAuth. El CLIENT_SECRET se configura solo en el servidor, nunca en GitHub.
GOOGLE_CLIENT_ID=1058535357714-cdufsvh40ajt6rb4hk8f7jhepc6paaf8.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CAMBIAR_EN_SERVIDOR
GOOGLE_CALLBACK_URL=http://ticketsbd.ddns.net/api/auth/google/callback

# Sesión/JWT. Generar una cadena larga en el servidor.
SESSION_SECRET=CAMBIAR_POR_SECRETO_LARGO

# Correos administradores iniciales separados por coma.
BOOTSTRAP_ADMIN_EMAILS=
